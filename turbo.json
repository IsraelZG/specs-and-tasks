{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build:tokens": {
      "outputs": ["build/web/**"]
    },
    "build": {
      "dependsOn": ["^build", "build:tokens"],
      "outputs": ["dist/**", "build/**"]
    },
    "test": {},
    "lint": {},
    "dev": { "cache": false, "persistent": true }
  }
}
