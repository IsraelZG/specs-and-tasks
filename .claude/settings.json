{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$j=[Console]::In.ReadToEnd()|ConvertFrom-Json; $f=$j.tool_input.file_path; if($f -and ($f -replace '\\\\', '/' -match '(?:^|/)packages/design-system/.*\\.metadata\\.ts$')){try{pnpm --filter @plataforma/design-system validate}catch{exit 1}}",
            "shell": "powershell",
            "timeout": 30,
            "statusMessage": "Validando metadados do design system e reconstruindo índice..."
          }
        ]
      }
    ]
  }
}
