{
  "name": "@plataforma/design-system",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-platform design system with theming support (light/dark + white-label).",
  "main": "build/react/index.js",
  "types": "build/react/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./build/react/index.js",
      "types": "./build/react/src/index.d.ts",
      "style": "./build/react/index.css"
    },
    "./theme-light.css": "./build/web/theme-light.css",
    "./theme-dark.css": "./build/web/theme-dark.css",
    "./theme-light": "./build/web/theme-light.js",
    "./theme-dark": "./build/web/theme-dark.js"
  },
  "scripts": {
    "build:tokens": "node style-dictionary.config.js && pnpm run build:index",
    "build:index": "node --experimental-strip-types scripts/build-component-index.mjs",
    "build:react": "vite build",
    "build": "pnpm run build:tokens && pnpm run build:react",
    "validate": "node --experimental-strip-types scripts/validate-metadata.mjs",
    "lint": "eslint src/",
    "test": "pnpm run validate && pnpm run typecheck && vitest run",
    "dev": "nodemon --watch tokens --watch src --ext json,ts,tsx,css --exec \"pnpm run build\"",
    "clean": "rm -rf build",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.2.1",
    "react-day-picker": "^10.0.1",
    "tailwind-merge": "^2.6.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.5.0",
    "jsdom": "^29.1.1",
    "nodemon": "^3.0.0",
    "style-dictionary": "^3.9.2",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^3.0.0"
  },
  "files": [
    "build",
    "tokens"
  ]
}
